# ============================================================
# CGM WhatsApp Assistant — configuration
#
# EVERYTHING here is optional. On first run the bot walks you
# through setup on WhatsApp itself (pairing code + questions).
# Values you do set here are used as defaults; values changed
# later via WhatsApp or the dashboard are stored in data/db.json
# and take priority.
# ============================================================

# ---- Language ----
# Bot reply language: en, ar (العربية), zh (中文), hi (हिन्दी), es, fr, pt
# Normally chosen during WhatsApp setup; command keywords stay English.
LANGUAGE=en

# ---- WhatsApp ----
# Phone number that receives alerts and controls the bot, digits only
# with country code (e.g. 14155552671). Leave empty to pair via the
# one-time code printed in the console on first run.
ADMIN_PHONE=

# ---- CGM provider: libre | dexcom ----
CGM_PROVIDER=libre

# FreeStyle Libre — a LibreLinkUp *follower* account (not your main
# LibreLink login). In the LibreLink app: Connected Apps -> LibreLinkUp,
# invite yourself, accept in the LibreLinkUp app.
LIBREVIEW_EMAIL=
LIBREVIEW_PASSWORD=
# Region is auto-detected; only set if you know it (e.g. eu, us, ae)
LIBREVIEW_REGION=

# Dexcom — your own Dexcom account (username, email or phone all work).
# Requires the Share feature enabled in the Dexcom app with at least
# one follower. Region: ous = outside US (default), us, jp
DEXCOM_USERNAME=
DEXCOM_PASSWORD=
DEXCOM_REGION=ous

# ---- AI meal analysis (optional but recommended) ----
# Get a key at https://openrouter.ai — used ONLY to estimate carbs/fat
# from meal photos and descriptions. Dose math never uses AI.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# ---- Dosing parameters ----
# The WhatsApp setup asks for these; set here only if you prefer files.
# Insulin-to-carb ratio: 1 unit covers X grams of carbs
CARB_RATIO=10
# Correction factor (ISF): 1 unit lowers glucose by X mg/dL
CORRECTION_FACTOR=50
# Target glucose (mg/dL)
TARGET_BG=110
# Hard cap for a single suggested bolus (units)
MAX_BOLUS=15
# Dose rounding increment: 1 = whole units (standard pens, e.g. 7.24 -> 7,
# 7.5 -> 8); set 0.5 for half-unit pens or 0.1 for pumps
DOSE_INCREMENT=1
# Percent adjustment per CGM trend-arrow step
TREND_ADJUST_PCT=10
# Duration of insulin action in hours (rapid analogs: 3-5)
DIA_HOURS=4

# ---- Fatty-meal dose splitting ----
# Suggest splitting when meal fat exceeds this (grams)
FAT_SPLIT_G=25
# First part percentage and delay of second part (minutes)
SPLIT_RATIO_PCT=50
SPLIT_DELAY_MIN=45

# ---- Alerts (mg/dL) ----
HIGH_ALERT=220
LOW_ALERT=70
PREDICT_HIGH_FROM=180
PREDICT_LOW_FROM=90
# How often to poll the CGM (minutes)
POLL_MINUTES=5
HIGH_COOLDOWN_MIN=45
LOW_COOLDOWN_MIN=15
# Re-check interval while glucose stays high (minutes)
FOLLOWUP_MIN=30

# ---- Learning engine (pure math, no AI) ----
TUNE_ENABLED=1
TUNE_MIN_MEALS=10
TUNE_COOLDOWN_DAYS=7
TUNE_MIN_RATIO=4
TUNE_MAX_RATIO=20

# ---- Web dashboard ----
# Dashboard is disabled unless a password (8+ chars) is set
DASH_PORT=8080
DASH_PASSWORD=
